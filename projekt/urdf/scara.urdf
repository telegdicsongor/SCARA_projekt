<?xml version="1.0"?>
<robot name="scara_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
    <material name="blue"><color rgba="0.0 0.0 0.8 1.0"/></material>
    <material name="red"><color rgba="0.8 0.0 0.0 1.0"/></material>

    <xacro:macro name="cylinder_inertia" params="m r h">
        <inertial>
            <mass value="${m}"/>
            <inertia ixx="${(m/12)*(3*r*r+h*h)}" ixy="0" ixz="0" iyy="${(m/12)*(3*r*r+h*h)}" iyz="0" izz="${(m/2)*(r*r)}"/>
        </inertial>
    </xacro:macro>
    <xacro:macro name="box_inertia" params="m x y z">
        <inertial>
            <mass value="${m}"/>
            <inertia ixx="${(m/12)*(y*y+z*z)}" ixy="0" ixz="0" iyy="${(m/12)*(x*x+z*z)}" iyz="0" izz="${(m/12)*(x*x+y*y)}"/>
        </inertial>
    </xacro:macro>

    <link name="base_footprint"/>

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <geometry><cylinder radius="0.1" length="0.2"/></geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.1" rpy="0 0 1.5708"/>
            <geometry><cylinder radius="0.1" length="0.2"/></geometry>
        </collision>
        <xacro:cylinder_inertia m="5.0" r="0.1" h="0.2"/>
    </link>

    <joint name="joint1" type="revolute">
        <parent link="base_link"/>
        <child link="link1"/>
        <origin xyz="0 0 0.2" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.5" upper="2.5" effort="100.0" velocity="1.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="link1">
        <visual>
            <origin xyz="0.15 0 0.05" rpy="0 0 0"/>
            <geometry><box size="0.3 0.08 0.1"/></geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0.15 0 0.05" rpy="0 0 0"/>
            <geometry><box size="0.3 0.08 0.1"/></geometry>
        </collision>
        <xacro:box_inertia m="2.0" x="0.3" y="0.08" z="0.1"/>
    </link>

    <joint name="joint2" type="revolute">
        <parent link="link1"/>
        <child link="link2"/>
        <origin xyz="0.3 0 0.1" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.5" upper="2.5" effort="100.0" velocity="1.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="link2">
        <visual>
            <origin xyz="0.1 0 0.05" rpy="0 0 0"/>
            <geometry><box size="0.2 0.06 0.1"/></geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="0.1 0 0.05" rpy="0 0 0"/>
            <geometry><box size="0.2 0.06 0.1"/></geometry>
        </collision>
        <xacro:box_inertia m="1.5" x="0.2" y="0.06" z="0.1"/>
    </link>

    <joint name="joint3" type="prismatic">
        <parent link="link2"/>
        <child link="end_effector"/>
        <origin xyz="0.2 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-0.15" upper="0.05" effort="50.0" velocity="0.5"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="end_effector">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><cylinder radius="0.02" length="0.3"/></geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><cylinder radius="0.02" length="0.3"/></geometry>
        </collision>
        <xacro:cylinder_inertia m="0.5" r="0.02" h="0.3"/>
    </link>

    <joint name="joint4" type="fixed">
        <origin xyz="0.0 0.0 -0.1" rpy="0 0 0"/>
        <parent link="end_effector"/>
        <child link="red_cube"/>
    </joint>

    <link name="red_cube">
        <visual>
            <origin xyz="0.0 0.0 -0.1" rpy="0 0 0"/>
            <geometry>
                <box size="0.01 0.01 0.01" />
            </geometry>
            <material name="red"/>
        </visual>
        <xacro:box_inertia m="0.01" x="0.01" y="0.08" z="0.01"/>
    </link>

    <ros2_control name="GazeboSystem" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>
        <joint name="joint1">
            <command_interface name="position">
                <param name="min">-2.5</param>
                <param name="max">2.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_value">0.0</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="joint2">
            <command_interface name="position">
                <param name="min">-2.5</param>
                <param name="max">2.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_value">0.0</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="joint3">
            <command_interface name="position">
                <param name="min">-0.15</param>
                <param name="max">0.05</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_value">0.0</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
    </ros2_control>

    <gazebo>
        <plugin filename="/opt/ros/jazzy/lib/libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(find projekt)/config/controller_position.yaml</parameters>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin filename="ignition-gazebo-detachable-joint-system" name="ignition::gazebo::systems::DetachableJoint">
            <parent_link>end_effector</parent_link>
            <child_model>wood_cube_5cm</child_model>
            <child_link>link</child_link>
            <detach_topic>/wood_cube_5cm/detach</detach_topic>
            <attach_topic>/wood_cube_5cm/attach</attach_topic>
            <output_topic>/wood_cube_5cm/state</output_topic>
        </plugin>
    </gazebo>
    

</robot>
